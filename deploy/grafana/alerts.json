  "description": "Inbound runtime alerts ingested by Fleetsweeper (AlertManager + Falco). Volume, ingest rate, and source breakdown.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "title": "AlertManager alerts ingested",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "fleetsweeper_alerts_received_total{source=\"alertmanager\"}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "title": "Falco events ingested",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "fleetsweeper_alerts_received_total{source=\"falco\"}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "id": 3,
      "title": "Ingest rate (5m)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "ops"
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "rate(fleetsweeper_alerts_received_total[5m])",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "id": 4,
      "title": "Cumulative alerts by source",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 25, "lineWidth": 1},
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "fleetsweeper_alerts_received_total",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ]
    }
