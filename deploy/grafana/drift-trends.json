{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Fleetsweeper drift trends. Tracks how the fleet's health moves over time and which clusters are dragging the average down.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 60},
              {"color": "yellow", "value": 70},
              {"color": "green", "value": 80}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "title": "Fleet Score over time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "fleetsweeper_fleet_score",
          "legendFormat": "Fleet Score",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "Findings by severity",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "sum by (severity) (fleetsweeper_findings_total)",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "title": "Outliers by cluster (modified z-score)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 0, "lineWidth": 1},
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "max by (cluster) (fleetsweeper_outlier_score)",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 4,
      "title": "Findings volume by scanner (critical + warning)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1},
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "sum by (scanner) (fleetsweeper_finding_count{severity=~\"critical|warning\"})",
          "legendFormat": "{{scanner}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 5,
      "title": "Scan duration (last completion)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 30},
              {"color": "red", "value": 120}
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${PROM_DS}"},
          "expr": "fleetsweeper_last_scan_duration_seconds",
          "legendFormat": "duration",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["fleetsweeper", "drift"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "PROM_DS",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Fleetsweeper – Drift trends",
  "uid": "fleetsweeper-drift-trends",
  "version": 1,
  "weekStart": ""
}
